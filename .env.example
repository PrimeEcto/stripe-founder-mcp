# Required: a Stripe API key with read permissions.
# Use a restricted key (rk_...) scoped to read-only access wherever possible.
# Create one at: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=

# Optional: cache TTL in seconds for tool responses (default: 60).
# Set to 0 to disable caching entirely.
CACHE_TTL_SECONDS=60

# Optional: maximum auto-paginated results per list operation (default: 1000).
MAX_LIST_RESULTS=1000
